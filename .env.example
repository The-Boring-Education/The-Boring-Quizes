# ===================================================================
# Quizes App - Next.js Environment Variables  
# Framework: Next.js (uses NEXT_PUBLIC_ prefix)
# ===================================================================

# ========== API URLs ==========
NEXT_PUBLIC_TBE_WEBAPP_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_WEBAPP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ONBOARDING_APP_URL=http://localhost:3003

# ========== AUTHENTICATION ==========
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ========== ANALYTICS ==========
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ========== ENVIRONMENT ==========
NODE_ENV=development
